# This file is used to ignore certain file types in a Unity project
# https://github.com/github/gitignore/blob/master/Unity.gitignore

# Ignore all local changes to tracked files
Temp/
Logs/
UserSettings/
obj/
Library/

# Ignore build results
Builds/
Build/
*.apk
*.unitypackage

# Never ignore Asset meta files, nor Frames folder
!/Assets/**/*.meta
!/Assets/Frames/

# Compiled class file
*.class

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

# Ignore .DS_Store files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Visual Studio cache/options
.vs/
.vscode/
*.csproj.user
*.sln.DotSettings.user

# Local environment
.env
.env.local
